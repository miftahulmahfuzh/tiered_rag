OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text:v1.5
EMBED_DIM=768
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge_base
CONFIDENCE_THRESHOLD=0.6

# --- Phase 2: routing / LLM backend ---
LLM_TYPE=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_BASE_URL=https://api.openai.com/v1
MOCK_LLM_BASE_URL=http://localhost:9101/v1
ROUTER_TEMPERATURE=0.0

# --- Phase 3: mock tier servers (separate ports) ---
MOCK_TIER2_BASE_URL=http://localhost:9102/v1
MOCK_TIER3_BASE_URL=http://localhost:9103/v1
# --- Phase 3: simulated token cost (USD per 1K tokens) ---
COST_INPUT_PER_1K=0.00015
COST_OUTPUT_PER_1K=0.00060
TIER2_COST_MULTIPLIER=3.0
TIER3_COST_MULTIPLIER=10.0

# --- Phase 5: zero-hallucination guardrails ---
VERIFY_ANSWERS=true            # run the verifier on grounded answers
ALERT_WEBHOOK_URL=             # empty -> log-only knowledge-gap alerts

# --- Phase 6: Tier-3 multi-step reasoning ---
TIER3_MAX_STEPS=5              # bound the chain length (cost/latency guard)

# --- Phase 7: high-scale engineering (cache + failover) ---
CACHE_ENABLED=true
REDIS_URL=redis://localhost:6379/0
CACHE_SIMILARITY_THRESHOLD=0.95   # near-duplicate queries only (high bar -> safe hits)
CACHE_TTL_SECONDS=3600
CACHE_MAX_ENTRIES=512             # bound the brute-force cosine scan
CACHE_KEY_PREFIX=tiered_rag:cache
# multiple workers per tier (comma-separated); empty -> the single MOCK_TIER{N}_BASE_URL
MOCK_TIER1_WORKERS=
MOCK_TIER2_WORKERS=
MOCK_TIER3_WORKERS=
HEALTH_CHECK_TIMEOUT=2.0
